# =============================================================
#  EASYPANEL — Variáveis de Ambiente para Produção
#  Cole este conteúdo na aba "Environment" do seu App no Easypanel
#  NÃO commite este arquivo com os segredos reais preenchidos!
# =============================================================

# ─── Banco de Dados ───────────────────────────────────────────
# Se usar o MongoDB criado no próprio Easypanel, use:
#   mongodb://mongo:27017   (nome do serviço no compose = mongo)
# Se usar MongoDB Atlas externo, cole a URI completa:
DATABASE_NAME=agenteia-prod
MONGODB_URI=mongodb://mongo:27017

# ─── JWT Secrets (gerar com: openssl rand -hex 32) ──────────
JWT_ACCESS_SECRET=COLE_AQUI_openssl_rand_hex_32
JWT_REFRESH_SECRET=COLE_AQUI_openssl_rand_hex_32

# ─── OAuth (deixe em branco se não usar) ─────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# ─── E-mail (Resend) ─────────────────────────────────────────
RESEND_API_KEY=
FROM_EMAIL=contato@agenteia.com.br
FROM_NAME=AgenteIA

# ─── Stripe (deixe vazio se não usar faturamento ainda) ──────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

# ─── App ─────────────────────────────────────────────────────
APP_NAME=AgenteIA

# ─── Servidor ────────────────────────────────────────────────
# No Easypanel o container roda na porta 8080 internamente
SERVER_HOST=0.0.0.0
SERVER_PORT=8080

# ─── URLs Públicas ───────────────────────────────────────────
# Substitua pelo seu domínio ou IP da VPS
# Ex: https://app.agenteia.com.br  ou  http://2.24.199.198
FRONTEND_URL=http://2.24.199.198
VITE_API_URL=http://2.24.199.198/api

# ─── OAuth Callbacks ─────────────────────────────────────────
GOOGLE_REDIRECT_URL=http://2.24.199.198/api/auth/google/callback
GITHUB_REDIRECT_URL=http://2.24.199.198/api/auth/github/callback
MICROSOFT_REDIRECT_URL=http://2.24.199.198/api/auth/microsoft/callback

# ─── Chat Up (Chatwoot) ──────────────────────────────────────
# URL do Chatwoot quando estiver no ar na VPS
VITE_CHATWOOT_URL=http://2.24.199.198:3100
# not_configured | deploying | active | maintenance
VITE_CHATWOOT_STATUS=active

# ─── Webhook N8N (se usar) ───────────────────────────────────
WEBHOOK_ENCRYPTION_KEY=
