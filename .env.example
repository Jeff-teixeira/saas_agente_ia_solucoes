SERVER_HOST=localhost
SERVER_PORT=4290
FRONTEND_URL=http://localhost:4280
VITE_PORT=4280
VITE_API_URL=http://localhost:4290
GOOGLE_REDIRECT_URL=http://localhost:4290/api/auth/google/callback
GITHUB_REDIRECT_URL=http://localhost:4290/api/auth/github/callback
MICROSOFT_REDIRECT_URL=http://localhost:4290/api/auth/microsoft/callback

# ─── Chat Up (Chatwoot) ──────────────────────────────────────────────────────
# URL da instância Chatwoot (ex: https://chat.seudominio.com.br)
# Deixe em branco para mostrar "Em implantação" no dashboard
VITE_CHATWOOT_URL=
# Status exibido no card: not_configured | deploying | active | maintenance
# Se omitido, é inferido automaticamente (URL vazia = deploying, URL preenchida = active)
VITE_CHATWOOT_STATUS=deploying
